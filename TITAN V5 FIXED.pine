//@version=5
indicator("🤖 TITAN AI V5 - PRO CAPITAL 🚀", overlay=true, max_lines_count=500, max_labels_count=500)

// ══════════════════════════════════════════════════
// ⚙️ SOZLAMALAR
// ══════════════════════════════════════════════════
g1 = "💰 Money Management"
accountsize  = input.float(2000.0, "Kapital ($)",       minval=1.0,  group=g1)
riskpertrade = input.float(1.0,    "Risk / treyd (%)",  minval=0.1,  step=0.1, group=g1)
maxslpoints  = input.float(30.0,   "Max SL (point)",    minval=3.0,  step=1.0, group=g1)
rrratio      = input.float(2.5,    "RR nisbat (TP/SL)", minval=1.0,  step=0.1, group=g1)
slbuf        = input.float(0.3,    "SL Buffer (ATR x)", minval=0.05, step=0.05, group=g1)

g2 = "📈 Trend"
htfval   = input.timeframe("60", "HTF Taymfreym", group=g2)
emaslow  = input.int(200, "HTF EMA",              group=g2)
swinglen = input.int(5,   "Swing uzunligi",        group=g2, minval=3, maxval=10)

// ══════════════════════════════════════════════════
// 🧠 HTF TREND
// ══════════════════════════════════════════════════
htfema       = request.security(syminfo.tickerid, htfval, ta.ema(close, emaslow))
bullishtrend = close > htfema
bearishtrend = close < htfema

// ══════════════════════════════════════════════════
// 📌 SWING HIGH / LOW
// ══════════════════════════════════════════════════
ph = ta.pivothigh(high, swinglen, swinglen)
pl = ta.pivotlow(low,  swinglen, swinglen)

var float lastpl     = na
var float lastph     = na
var int   lastpl_bar = na
var int   lastph_bar = na

if not na(pl)
    lastpl     := pl
    lastpl_bar := bar_index - swinglen
if not na(ph)
    lastph     := ph
    lastph_bar := bar_index - swinglen

if not na(ph)
    line.new(bar_index - swinglen, ph, bar_index, ph, color=color.new(color.red,  60), style=line.style_dotted)
if not na(pl)
    line.new(bar_index - swinglen, pl, bar_index, pl, color=color.new(color.lime, 60), style=line.style_dotted)

// ══════════════════════════════════════════════════
// 📐 ATR
// ══════════════════════════════════════════════════
atr = ta.atr(14)

// ══════════════════════════════════════════════════
// 🎯 AQLLI SL — Swing tagiga / ustiga
// ══════════════════════════════════════════════════
float buysl   = na
float sellsl  = na
float buy_sd  = na
float sell_sd = na

if not na(lastpl)
    buysl  := lastpl - atr * slbuf
    buy_sd := close - buysl

if not na(lastph)
    sellsl  := lastph + atr * slbuf
    sell_sd := sellsl - close

// ══════════════════════════════════════════════════
// 🚨 SIGNALLAR
// ══════════════════════════════════════════════════
buysignal  = bullishtrend and not na(lastpl) and low < lastpl and close > lastpl and close > open and not na(buy_sd)  and buy_sd  > 0 and buy_sd  <= maxslpoints
sellsignal = bearishtrend and not na(lastph) and high > lastph and close < lastph and close < open and not na(sell_sd) and sell_sd > 0 and sell_sd <= maxslpoints

// ══════════════════════════════════════════════════
// 💰 LOT HISOBLASH
// Lot = (Kapital × Risk%) / (SL_point × 100)
// ══════════════════════════════════════════════════
var float tradelot = na
var float sldist   = na
riskamt = accountsize * (riskpertrade / 100)

if buysignal
    sldist   := buy_sd
    tradelot := math.max(math.round(riskamt / (buy_sd * 100), 2), 0.01)

if sellsignal
    sldist   := sell_sd
    tradelot := math.max(math.round(riskamt / (sell_sd * 100), 2), 0.01)

// ══════════════════════════════════════════════════
// 📊 WIN RATE
// ══════════════════════════════════════════════════
var int   totaltrades = 0
var int   wins        = 0
var float wr          = 0.0

if buysignal or sellsignal
    totaltrades += 1
if buysignal and ta.crossover(high, close + buy_sd * rrratio)
    wins += 1
if sellsignal and ta.crossunder(low, close - sell_sd * rrratio)
    wins += 1

wr := totaltrades > 0 ? (wins / totaltrades) * 100 : 0.0

// ══════════════════════════════════════════════════
// 🖼️ VIZUAL — Label va chiziqlar
// ══════════════════════════════════════════════════
if buysignal and not na(tradelot)
    tp_buy  = close + buy_sd * rrratio
    profUSD = math.round(tradelot * buy_sd * rrratio * 100, 2)
    lbl = "💎 BUY\n⏰ " + timeframe.period + "m\n📦 Lot: " + str.tostring(tradelot, "#.##") + "\n🛑 SL: " + str.tostring(buysl, "#.##") + " (" + str.tostring(buy_sd, "#.#") + "pt)\n🎯 TP: " + str.tostring(tp_buy, "#.##") + "\n⚠️ $" + str.tostring(riskamt, "#.##") + " → 💵 $" + str.tostring(profUSD, "#.##")
    label.new(bar_index, low, lbl, color=color.new(#00c853, 0), textcolor=color.white, style=label.style_label_up, size=size.normal)
    line.new(bar_index, close,  bar_index + 15, close,  color=color.yellow, style=line.style_dashed)
    line.new(bar_index, buysl,  bar_index + 15, buysl,  color=color.red,    width=2)
    line.new(bar_index, tp_buy, bar_index + 15, tp_buy, color=color.lime,   width=2)

if sellsignal and not na(tradelot)
    tp_sell = close - sell_sd * rrratio
    profUSD = math.round(tradelot * sell_sd * rrratio * 100, 2)
    lbl = "☢️ SELL\n⏰ " + timeframe.period + "m\n📦 Lot: " + str.tostring(tradelot, "#.##") + "\n🛑 SL: " + str.tostring(sellsl, "#.##") + " (" + str.tostring(sell_sd, "#.#") + "pt)\n🎯 TP: " + str.tostring(tp_sell, "#.##") + "\n⚠️ $" + str.tostring(riskamt, "#.##") + " → 💵 $" + str.tostring(profUSD, "#.##")
    label.new(bar_index, high, lbl, color=color.new(#d50000, 0), textcolor=color.white, style=label.style_label_down, size=size.normal)
    line.new(bar_index, close,   bar_index + 15, close,   color=color.yellow, style=line.style_dashed)
    line.new(bar_index, sellsl,  bar_index + 15, sellsl,  color=color.red,    width=2)
    line.new(bar_index, tp_sell, bar_index + 15, tp_sell, color=color.lime,   width=2)

// ══════════════════════════════════════════════════
// 📋 DASHBOARD
// ══════════════════════════════════════════════════
var table dash = table.new(position.top_right, 2, 8, bgcolor=color.new(#0d1117, 0), border_width=1, border_color=color.new(color.gray, 50), frame_width=2, frame_color=color.gold)

if barstate.islast
    table.cell(dash, 0, 0, "🤖 TITAN V5 PRO",      text_color=color.gold,   bgcolor=color.new(#1a1f2e, 0), text_size=size.normal)
    table.cell(dash, 1, 0, "💰 $" + str.tostring(accountsize, "#"), text_color=color.white, bgcolor=color.new(#1a1f2e, 0), text_size=size.normal)
    table.cell(dash, 0, 1, "📈 HTF Trend",           text_color=color.gray,  text_size=size.small)
    table.cell(dash, 1, 1, bullishtrend ? "BULLISH 🟢" : "BEARISH 🔴", text_color=bullishtrend ? color.lime : color.red, bgcolor=bullishtrend ? color.new(color.green, 80) : color.new(color.red, 80), text_size=size.small)
    table.cell(dash, 0, 2, "🏆 Win Rate",             text_color=color.gray,  text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(wr, "#.#") + "% (" + str.tostring(wins) + "/" + str.tostring(totaltrades) + ")", text_color=color.white, bgcolor=wr >= 55 ? color.new(color.green, 70) : wr >= 45 ? color.new(color.orange, 70) : color.new(color.red, 70), text_size=size.small)
    table.cell(dash, 0, 3, "📦 So'ngi Lot",           text_color=color.gray,  text_size=size.small)
    table.cell(dash, 1, 3, not na(tradelot) ? str.tostring(tradelot, "#.##") + " lot" : "— kutilmoqda", text_color=color.orange, text_size=size.small)
    table.cell(dash, 0, 4, "📏 SL masofa",            text_color=color.gray,  text_size=size.small)
    table.cell(dash, 1, 4, not na(sldist) ? str.tostring(sldist, "#.#") + " pt" : "—", text_color=not na(sldist) and sldist <= maxslpoints ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 5, "⚠️ Risk ($)",             text_color=color.gray,  text_size=size.small)
    table.cell(dash, 1, 5, "$" + str.tostring(riskamt, "#.##"),  text_color=color.yellow, text_size=size.small)
    table.cell(dash, 0, 6, "🚧 Max SL / RR",          text_color=color.gray,  text_size=size.small)
    table.cell(dash, 1, 6, str.tostring(maxslpoints, "#") + " pt | 1:" + str.tostring(rrratio, "#.#"), text_color=color.aqua, text_size=size.small)
    table.cell(dash, 0, 7, "⏰ Taymfreym",             text_color=color.gray,  text_size=size.small)
    table.cell(dash, 1, 7, timeframe.period + " min",  text_color=color.white, text_size=size.small)

// ══════════════════════════════════════════════════
// 📡 TELEGRAM ALERT — alert() ishlatiladi (series string qabul qiladi)
// alertcondition() emas! U faqat const string qabul qilardi.
// ══════════════════════════════════════════════════
if buysignal and not na(tradelot)
    tp_b = close + buy_sd * rrratio
    msg = '{"signal":"BUY","symbol":"' + syminfo.ticker + '","tf":"' + timeframe.period + '","price":"' + str.tostring(close, "#.##") + '","sl":"' + str.tostring(buysl, "#.##") + '","tp":"' + str.tostring(tp_b, "#.##") + '","lot":"' + str.tostring(tradelot, "#.##") + '","sldist":"' + str.tostring(buy_sd, "#.#") + '","risk":"' + str.tostring(riskamt, "#.##") + '"}'
    alert(msg, alert.freq_once_per_bar_close)

if sellsignal and not na(tradelot)
    tp_s = close - sell_sd * rrratio
    msg = '{"signal":"SELL","symbol":"' + syminfo.ticker + '","tf":"' + timeframe.period + '","price":"' + str.tostring(close, "#.##") + '","sl":"' + str.tostring(sellsl, "#.##") + '","tp":"' + str.tostring(tp_s, "#.##") + '","lot":"' + str.tostring(tradelot, "#.##") + '","sldist":"' + str.tostring(sell_sd, "#.#") + '","risk":"' + str.tostring(riskamt, "#.##") + '"}'
    alert(msg, alert.freq_once_per_bar_close)
